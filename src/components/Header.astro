---
import OrbitMark from "./OrbitMark.astro";

const path = Astro.url.pathname;
const links = [
  { href: "/", label: "首頁" },
  { href: "/about", label: "關於" },
  { href: "/products", label: "產品" },
  { href: "/contact", label: "聯絡" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-transparent transition-colors duration-300"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-10"
  >
    <a
      href="/"
      class="group flex items-center gap-3"
      aria-label="動域科技 首頁"
    >
      <OrbitMark size={34} spin={true} />
      <div class="leading-tight">
        <p class="font-display text-base font-bold text-paper">Dongyu Tech</p>
        <p class="text-xs tracking-[0.3em] text-muted">動域科技</p>
      </div>
    </a>

    <!-- 桌面導覽 -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        links
          .filter((l) => l.href !== "/contact")
          .map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  "relative text-sm font-medium transition-colors hover:text-paper",
                  isActive(l.href) ? "text-paper" : "text-muted",
                ]}
              >
                {l.label}
                {isActive(l.href) && (
                  <span class="absolute -bottom-1.5 left-0 h-0.5 w-full bg-orbit" />
                )}
              </a>
            </li>
          ))
      }
      <li>
        <a
          href="/contact"
          class="rounded-full bg-orbit px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-orbit-bright"
        >
          聯絡我們
        </a>
      </li>
    </ul>

    <!-- 行動裝置:漢堡按鈕 -->
    <button
      id="menu-toggle"
      class="flex flex-col gap-1.5 p-2 md:hidden"
      aria-label="開啟選單"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-paper transition-transform"></span>
      <span class="block h-0.5 w-6 bg-paper transition-opacity"></span>
      <span class="block h-0.5 w-6 bg-paper transition-transform"></span>
    </button>
  </nav>

  <!-- 行動裝置選單 -->
  <div
    id="mobile-menu"
    class="absolute inset-x-0 top-full z-40 border-t border-ink-line bg-ink shadow-xl shadow-black/40 md:hidden"
  >
    <ul class="flex flex-col px-6 py-4">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "block py-3 text-base font-medium",
                isActive(l.href) ? "text-orbit" : "text-paper",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  /* 置頂時透明,捲動超過門檻後淡入墨底 + 毛玻璃 + 分隔線 */
  #site-header {
    backdrop-filter: blur(0px);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      backdrop-filter 0.3s ease;
  }
  #site-header[data-scrolled] {
    background-color: color-mix(in oklab, var(--color-ink) 80%, transparent);
    border-bottom-color: color-mix(
      in oklab,
      var(--color-ink-line) 70%,
      transparent
    );
    backdrop-filter: blur(12px);
  }

  /* 行動選單:淡入淡出(關閉時淡出並隱藏,避免仍可點擊) */
  #mobile-menu {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0.25s ease;
  }
  #mobile-menu[data-open] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    #mobile-menu {
      transition: none;
      transform: none;
    }
  }
</style>

<script>
  function setupMenu() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu) return;
    toggle.addEventListener("click", () => {
      const isOpen = menu.toggleAttribute("data-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }

  // 置頂(0~50)透明,捲過 50px 後加上 data-scrolled
  function updateHeader() {
    const header = document.getElementById("site-header");
    if (!header) return;
    header.toggleAttribute("data-scrolled", window.scrollY > 50);
  }

  // scroll 監聽只綁一次(module 只執行一次,window 不會被 View Transitions 換掉)
  window.addEventListener("scroll", updateHeader, { passive: true });
  // 每次 View Transitions 導覽都重跑:重綁選單 + 重設 header 初始狀態
  document.addEventListener("astro:page-load", () => {
    setupMenu();
    updateHeader();
  });
</script>
